<Window x:Class="WindosRecorder.LanguageSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460"
        Height="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#F4F6FB">
  <Grid Margin="18">
    <Border Background="White"
            BorderBrush="#E5EAF2"
            BorderThickness="1"
            CornerRadius="24"
            Padding="22">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#1F2D3D"
                   Text="选择语言" />

        <TextBlock x:Name="SubtitleTextBlock"
                   Grid.Row="1"
                   Margin="0,8,0,0"
                   Foreground="#73829A"
                   FontSize="13"
                   Text="请选择界面语言 / Choose the interface language" />

        <UniformGrid Grid.Row="2"
                     Margin="0,20,0,0"
                     Columns="2">
          <Button x:Name="ChineseButton"
                  Margin="0,0,10,0"
                  Height="140"
                  Click="ChineseButton_OnClick">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="#FFFFFF"
                        BorderBrush="#33D399"
                        BorderThickness="1.5"
                        CornerRadius="22">
                  <StackPanel HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <TextBlock Text="中"
                               Foreground="#1CB770"
                               FontSize="34"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="中文"
                               Margin="0,8,0,0"
                               Foreground="#1F2D3D"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>

          <Button x:Name="EnglishButton"
                  Margin="10,0,0,0"
                  Height="140"
                  Click="EnglishButton_OnClick">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="#FFFFFF"
                        BorderBrush="#DDE4EF"
                        BorderThickness="1.5"
                        CornerRadius="22">
                  <StackPanel HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                    <TextBlock Text="EN"
                               Foreground="#4A67A1"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="English"
                               Margin="0,8,0,0"
                               Foreground="#1F2D3D"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </UniformGrid>
      </Grid>
    </Border>
  </Grid>
</Window>
