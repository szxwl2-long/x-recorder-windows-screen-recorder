<Window x:Class="WindosRecorder.CountdownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="300"
        Height="220"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen">
  <Border Background="#DD0F172A"
          CornerRadius="24"
          Padding="20">
    <StackPanel VerticalAlignment="Center">
      <TextBlock x:Name="TitleTextBlock"
                 HorizontalAlignment="Center"
                 Foreground="White"
                 FontSize="20"
                 FontWeight="SemiBold"
                 Text="即将开始录制" />
      <TextBlock x:Name="SecondsTextBlock"
                 Margin="0,12,0,0"
                 HorizontalAlignment="Center"
                 Foreground="#F8FAFC"
                 FontSize="56"
                 FontWeight="Bold"
                 Text="5" />
      <TextBlock x:Name="HintTextBlock"
                 Margin="0,10,0,0"
                 HorizontalAlignment="Center"
                 Foreground="#CBD5E1"
                 FontSize="12"
                 TextWrapping="Wrap"
                 TextAlignment="Center" />
    </StackPanel>
  </Border>
</Window>
