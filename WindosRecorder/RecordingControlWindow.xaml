<Window x:Class="WindosRecorder.RecordingControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="500"
        Height="310"
        MinWidth="500"
        MinHeight="310"
        WindowStartupLocation="Manual"
        ResizeMode="CanMinimize"
        Topmost="True"
        ShowInTaskbar="True"
        WindowStyle="SingleBorderWindow"
        Background="#F4F6FB">
  <Window.Resources>
    <Style x:Key="OutlineControlButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#D7DFEB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#304056" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="16">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.45" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>
  <Grid Margin="14">
    <Border Background="White"
            BorderBrush="#E5EAF2"
            BorderThickness="1"
            CornerRadius="22"
            Padding="16">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel>
          <TextBlock x:Name="TitleTextBlock"
                     Foreground="#1F2D3D"
                     FontSize="18"
                     FontWeight="SemiBold" />
          <Border DockPanel.Dock="Right"
                  Background="#EEF4FF"
                  CornerRadius="12"
                  Padding="10,4">
            <TextBlock x:Name="ElapsedTextBlock"
                       Foreground="#244A96"
                       FontSize="18"
                       FontWeight="Bold"
                       Text="00:00:00" />
          </Border>
        </DockPanel>

        <Grid x:Name="SystemAudioVolumePanel"
              Grid.Row="1"
              Margin="0,14,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="82" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="36" />
            <ColumnDefinition Width="38" />
            <ColumnDefinition Width="36" />
            <ColumnDefinition Width="48" />
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="SystemAudioVolumeLabelTextBlock"
                     VerticalAlignment="Center"
                     Foreground="#53627C"
                     FontSize="12"
                     FontWeight="SemiBold" />
          <Slider x:Name="SystemAudioSlider"
                  Grid.Column="1"
                  Minimum="1"
                  Maximum="100"
                  Value="100"
                  TickFrequency="1"
                  IsSnapToTickEnabled="True"
                  ValueChanged="SystemAudioSlider_OnValueChanged" />
          <Button x:Name="SystemAudioMinusButton"
                  Grid.Column="2"
                  Margin="6,0,0,0"
                  Click="SystemAudioMinusButton_OnClick"
                  Content="-" />
          <TextBlock x:Name="SystemAudioValueTextBlock"
                     Grid.Column="3"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Foreground="#1F2D3D"
                     FontWeight="SemiBold"
                     Text="100" />
          <Button x:Name="SystemAudioPlusButton"
                  Grid.Column="4"
                  Margin="6,0,0,0"
                  Click="SystemAudioPlusButton_OnClick"
                  Content="+" />
          <Border Grid.Column="5"
                  Margin="6,0,0,0"
                  Background="Transparent" />
        </Grid>

        <Grid x:Name="MicrophoneVolumePanel"
              Grid.Row="2"
              Margin="0,10,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="82" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="36" />
            <ColumnDefinition Width="38" />
            <ColumnDefinition Width="36" />
            <ColumnDefinition Width="48" />
          </Grid.ColumnDefinitions>
          <TextBlock x:Name="MicrophoneVolumeLabelTextBlock"
                     VerticalAlignment="Center"
                     Foreground="#53627C"
                     FontSize="12"
                     FontWeight="SemiBold" />
          <Slider x:Name="MicrophoneSlider"
                  Grid.Column="1"
                  Minimum="1"
                  Maximum="100"
                  Value="100"
                  TickFrequency="1"
                  IsSnapToTickEnabled="True"
                  ValueChanged="MicrophoneSlider_OnValueChanged" />
          <Button x:Name="MicrophoneMinusButton"
                  Grid.Column="2"
                  Margin="6,0,0,0"
                  Click="MicrophoneMinusButton_OnClick"
                  Content="-" />
          <TextBlock x:Name="MicrophoneValueTextBlock"
                     Grid.Column="3"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     Foreground="#1F2D3D"
                     FontWeight="SemiBold"
                     Text="100" />
          <Button x:Name="MicrophonePlusButton"
                  Grid.Column="4"
                  Margin="6,0,0,0"
                  Click="MicrophonePlusButton_OnClick"
                  Content="+" />
          <Button x:Name="MicrophoneBoostButton"
                  Grid.Column="5"
                  Margin="6,0,0,0"
                  Click="MicrophoneBoostButton_OnClick"
                  Content="x1" />
        </Grid>

        <TextBlock x:Name="RecordingHintTextBlock"
                   Grid.Row="3"
                   Margin="0,12,0,0"
                   Foreground="#7B889C"
                   FontSize="12"
                   TextWrapping="Wrap" />

        <UniformGrid Grid.Row="4"
                     Margin="0,14,0,0"
                     Rows="1"
                     Columns="2">
          <Button x:Name="PauseResumeButton"
                  Height="46"
                  Margin="0,0,8,0"
                  Padding="12,0"
                  Style="{StaticResource OutlineControlButtonStyle}"
                  Click="PauseResumeButton_OnClick" />
          <Button x:Name="StopButtonControl"
                  Height="46"
                  Margin="8,0,0,0"
                  Padding="12,0"
                  Style="{StaticResource OutlineControlButtonStyle}"
                  Click="StopButtonControl_OnClick" />
        </UniformGrid>
      </Grid>
    </Border>
  </Grid>
</Window>
