<Window x:Class="WindosRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="1000"
        Height="780"
        MinWidth="960"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F4F6FB">
  <Window.Resources>
    <Style x:Key="CardBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="White" />
      <Setter Property="CornerRadius" Value="22" />
      <Setter Property="Padding" Value="16" />
      <Setter Property="BorderBrush" Value="#E5EAF2" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#53627C" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="Margin" Value="0,6,0,0" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Background" Value="#F7F9FD" />
      <Setter Property="BorderBrush" Value="#D8DFEB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Height" Value="38" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Margin" Value="0,6,0,0" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="Background" Value="#F7F9FD" />
      <Setter Property="BorderBrush" Value="#D8DFEB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Height" Value="38" />
    </Style>

    <Style x:Key="ModeButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#DDE4EF" />
      <Setter Property="BorderThickness" Value="1.5" />
      <Setter Property="Foreground" Value="#304056" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Height" Value="88" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="20">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Background" Value="#F3F6FB" />
      <Setter Property="BorderBrush" Value="#D7DFEB" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#34445D" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="16">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Height" Value="56" />
      <Setter Property="Padding" Value="18,0" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="#204EAF" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#204EAF" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="22">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border x:Name="HeroCardBorder"
            Grid.Row="0"
            Style="{StaticResource CardBorderStyle}"
            Padding="16,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.15*" />
          <ColumnDefinition Width="1.1*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock x:Name="HeroTitleTextBlock"
                     FontSize="26"
                     FontWeight="SemiBold"
                     Foreground="#1F2D3D" />
          <TextBlock x:Name="HeroSubtitleTextBlock"
                     Margin="0,5,0,0"
                     Foreground="#6A7890"
                     FontSize="13"
                     TextWrapping="Wrap" />
          <TextBlock x:Name="SettingsTitleTextBlock"
                     Visibility="Collapsed" />
        </StackPanel>

        <Button x:Name="SupportAuthorButton"
                Grid.Column="1"
                Margin="16,0,16,0"
                MinWidth="260"
                Height="74"
                Background="#F7F9FD"
                BorderBrush="#DDE5F1"
                BorderThickness="1"
                Cursor="Hand"
                Click="SupportAuthorButton_OnClick">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="16"
                      Padding="12,8">
                <ContentPresenter />
              </Border>
            </ControlTemplate>
          </Button.Template>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
              <TextBlock x:Name="SupportAuthorTitleTextBlock"
                         Foreground="#1F2D3D"
                         FontSize="15"
                         FontWeight="SemiBold" />
              <TextBlock x:Name="SupportAuthorSubtitleTextBlock"
                         Margin="0,4,0,0"
                         Foreground="#6A7890"
                         FontSize="11"
                         TextWrapping="Wrap" />
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="#244A96"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Text="¥" />
          </Grid>
        </Button>

        <Border Grid.Column="2"
                Background="#EEF4FF"
                CornerRadius="16"
                Padding="12,8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="AuthorTextBlock"
                       HorizontalAlignment="Right"
                       Foreground="#1F2D3D"
                       FontSize="26"
                       FontWeight="SemiBold"
                       Text="Author: long-X" />
            <TextBlock x:Name="StatusLabelTextBlock"
                       Grid.Row="1"
                       Margin="0,6,0,0"
                       Foreground="#6A7890"
                       FontSize="12"
                       FontWeight="SemiBold" />
            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="2"
                       Margin="0,3,0,0"
                       Foreground="#244A96"
                       FontSize="13"
                       FontWeight="SemiBold" />
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Grid x:Name="BodyContentGrid"
          Grid.Row="1"
          Margin="0,14,0,14">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2.4*" />
        <ColumnDefinition Width="1.05*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Style="{StaticResource CardBorderStyle}"
              Margin="0,0,14,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <ComboBox x:Name="ModeComboBox"
                    Visibility="Collapsed"
                    SelectionChanged="ModeComboBox_OnSelectionChanged" />

          <TextBlock x:Name="ModeLabelTextBlock"
                     Style="{StaticResource SectionLabelStyle}" />

          <UniformGrid x:Name="ModeButtonsPanel"
                       Grid.Row="1"
                       Margin="0,8,0,0"
                       Columns="3">
            <Button x:Name="FullScreenModeButton"
                    Margin="0,0,8,0"
                    Style="{StaticResource ModeButtonStyle}"
                    Click="FullScreenModeButton_OnClick">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="▣"
                           FontSize="22"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="FullScreenModeTitleTextBlock"
                           Margin="0,6,0,0"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="WindowModeButton"
                    Margin="4,0"
                    Style="{StaticResource ModeButtonStyle}"
                    Click="WindowModeButton_OnClick">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="▤"
                           FontSize="22"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="WindowModeTitleTextBlock"
                           Margin="0,6,0,0"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Button>

            <Button x:Name="AudioOnlyModeButton"
                    Margin="8,0,0,0"
                    Style="{StaticResource ModeButtonStyle}"
                    Click="AudioOnlyModeButton_OnClick">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="◉"
                           FontSize="22"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="AudioOnlyModeTitleTextBlock"
                           Margin="0,6,0,0"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Button>
          </UniformGrid>

          <StackPanel x:Name="WindowSelectorPanel"
                      Grid.Row="2"
                      Margin="0,12,0,0">
            <TextBlock x:Name="WindowLabelTextBlock"
                       Style="{StaticResource SectionLabelStyle}" />
            <Grid Margin="0,6,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="104" />
                <ColumnDefinition Width="104" />
              </Grid.ColumnDefinitions>
              <ComboBox x:Name="WindowComboBox"
                        Margin="0"
                        Visibility="Collapsed" />
              <TextBox x:Name="SelectedWindowTextBox"
                       Margin="0"
                       IsReadOnly="True" />
              <Button x:Name="RefreshWindowsButton"
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="RefreshWindowsButton_OnClick" />
              <Button x:Name="ChooseWindowButton"
                      Grid.Column="2"
                      Margin="8,0,0,0"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Click="ChooseWindowButton_OnClick" />
            </Grid>
          </StackPanel>

          <Grid x:Name="SettingsCardsGrid"
                Grid.Row="3"
                Margin="0,12,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,8,0"
                    Background="#F7F9FD"
                    BorderBrush="#E0E6F0"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="12">
              <StackPanel>
                <DockPanel LastChildFill="False">
                  <TextBlock x:Name="MicrophoneLabelTextBlock"
                             Style="{StaticResource SectionLabelStyle}" />
                  <CheckBox x:Name="IncludeMicrophoneCheckBox"
                            DockPanel.Dock="Right"
                            Foreground="#32435B"
                            FontWeight="SemiBold"
                            IsChecked="True"
                            Click="IncludeMicrophoneCheckBox_OnClick" />
                </DockPanel>

                <ComboBox x:Name="MicrophoneComboBox" />

                <Grid x:Name="MicrophoneVolumePanel"
                      Margin="0,10,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="68" />
                    <ColumnDefinition Width="6" />
                    <ColumnDefinition Width="88" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="28" />
                  </Grid.ColumnDefinitions>
                  <TextBlock x:Name="MicrophoneVolumeLabelTextBlock"
                             VerticalAlignment="Center"
                             Style="{StaticResource SectionLabelStyle}" />
                  <Border Grid.Column="1"
                          Background="Transparent" />
                  <Slider x:Name="MicrophoneSlider"
                          Grid.Column="2"
                          VerticalAlignment="Center"
                          Minimum="1"
                          Maximum="100"
                          Value="100"
                          TickFrequency="1"
                          IsSnapToTickEnabled="True"
                          ValueChanged="MicrophoneSlider_OnValueChanged" />
                  <Button x:Name="MicrophoneMinusButton"
                          Grid.Column="3"
                          Margin="6,0,0,0"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Click="MicrophoneMinusButton_OnClick"
                          Content="-" />
                  <TextBlock x:Name="MicrophoneValueTextBlock"
                             Grid.Column="4"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="#1F2D3D"
                             FontWeight="SemiBold"
                             Text="100" />
                  <Button x:Name="MicrophonePlusButton"
                          Grid.Column="5"
                          Margin="6,0,0,0"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Click="MicrophonePlusButton_OnClick"
                          Content="+" />
                  <Button x:Name="MicrophoneBoostButton"
                          Grid.Column="6"
                          Margin="6,0,0,0"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Click="MicrophoneBoostButton_OnClick"
                          Content="x1" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="8,0,0,0"
                    Background="#F7F9FD"
                    BorderBrush="#E0E6F0"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="12">
              <StackPanel>
                <DockPanel LastChildFill="False">
                  <TextBlock x:Name="SystemAudioCardTitleTextBlock"
                             Style="{StaticResource SectionLabelStyle}" />
                  <CheckBox x:Name="IncludeSystemAudioCheckBox"
                            DockPanel.Dock="Right"
                            Foreground="#32435B"
                            FontWeight="SemiBold"
                            IsChecked="True"
                            Click="IncludeSystemAudioCheckBox_OnClick" />
                </DockPanel>

                <TextBlock x:Name="SystemAudioDescriptionTextBlock"
                           Margin="0,6,0,0"
                           Foreground="#7A889E"
                           FontSize="12"
                           TextWrapping="Wrap" />

                <Grid x:Name="SystemAudioVolumePanel"
                      Margin="0,10,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="84" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="95" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="26" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="30" />
                  </Grid.ColumnDefinitions>
                  <TextBlock x:Name="SystemAudioVolumeLabelTextBlock"
                             VerticalAlignment="Center"
                             Style="{StaticResource SectionLabelStyle}" />
                  <Border Grid.Column="1"
                          Background="Transparent" />
                  <Slider x:Name="SystemAudioSlider"
                          Grid.Column="2"
                          VerticalAlignment="Center"
                          Minimum="1"
                          Maximum="100"
                          Value="100"
                          TickFrequency="1"
                          IsSnapToTickEnabled="True"
                          ValueChanged="SystemAudioSlider_OnValueChanged" />
                  <Button x:Name="SystemAudioMinusButton"
                          Grid.Column="3"
                          Margin="6,0,0,0"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Click="SystemAudioMinusButton_OnClick"
                          Content="-" />
                  <TextBlock x:Name="SystemAudioValueTextBlock"
                             Grid.Column="4"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Foreground="#1F2D3D"
                             FontWeight="SemiBold"
                             Text="100" />
                  <Button x:Name="SystemAudioPlusButton"
                          Grid.Column="5"
                          Margin="6,0,0,0"
                          Style="{StaticResource SecondaryButtonStyle}"
                          Click="SystemAudioPlusButton_OnClick"
                          Content="+" />
                  <Border Grid.Column="6"
                          Margin="6,0,0,0"
                          Background="Transparent" />
                </Grid>
              </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,10,8,0"
                    Background="#F7F9FD"
                    BorderBrush="#E0E6F0"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,6,0">
                  <TextBlock x:Name="ResolutionLabelTextBlock"
                             Style="{StaticResource SectionLabelStyle}" />
                  <ComboBox x:Name="ResolutionComboBox"
                            SelectionChanged="ResolutionComboBox_OnSelectionChanged" />
                  <TextBlock x:Name="StorageEstimateTextBlock"
                             Margin="0,8,0,0"
                             Foreground="#6A7890"
                             FontSize="11"
                             TextWrapping="Wrap" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Margin="6,0,0,0">
                  <TextBlock x:Name="FrameRateLabelTextBlock"
                             Style="{StaticResource SectionLabelStyle}" />
                  <ComboBox x:Name="FrameRateComboBox"
                            SelectionChanged="FrameRateComboBox_OnSelectionChanged" />
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="1"
                    Margin="8,10,0,0"
                    Background="#F7F9FD"
                    BorderBrush="#E0E6F0"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="12">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="92" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="BitrateLabelTextBlock"
                           Grid.Row="1"
                           VerticalAlignment="Center"
                           Style="{StaticResource SectionLabelStyle}" />
                <TextBlock x:Name="BitrateHintTextBlock"
                           Grid.ColumnSpan="2"
                           Margin="0,0,0,6"
                           Foreground="#6A7890"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <TextBox x:Name="BitrateTextBox"
                         Grid.Row="1"
                         Grid.Column="1"
                         Margin="8,0,0,0"
                         TextChanged="BitrateTextBox_OnTextChanged"
                         Text="12000" />

                <TextBlock x:Name="RecordingNameLabelTextBlock"
                           Grid.Row="2"
                           Margin="0,8,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource SectionLabelStyle}" />
                <ComboBox x:Name="RecordingNameComboBox"
                          Grid.Row="2"
                          Grid.Column="1"
                          Margin="8,8,0,0"
                          IsEditable="True"
                          IsTextSearchEnabled="False"
                          StaysOpenOnEdit="True"
                          SelectionChanged="RecordingNameComboBox_OnSelectionChanged" />
                <TextBlock x:Name="RecordingNameHintTextBlock"
                           Grid.Row="3"
                           Grid.ColumnSpan="2"
                           Margin="0,6,0,0"
                           Foreground="#8A98AE"
                           FontSize="11"
                           TextWrapping="Wrap" />
              </Grid>
            </Border>
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Column="1"
              Style="{StaticResource CardBorderStyle}">
        <StackPanel>
          <TextBlock x:Name="SaveTitleTextBlock"
                     FontSize="18"
                     FontWeight="SemiBold"
                     Foreground="#1F2D3D" />
          <TextBlock x:Name="SaveDescriptionTextBlock"
                     Margin="0,6,0,0"
                     Foreground="#7B889C"
                     FontSize="12"
                     TextWrapping="Wrap" />

          <TextBox x:Name="SaveFolderTextBox"
                   Margin="0,12,0,0"
                   IsReadOnly="True" />

          <Button x:Name="ChooseFolderButton"
                  Margin="0,10,0,0"
                  Style="{StaticResource SecondaryButtonStyle}"
                  Click="ChooseFolderButton_OnClick" />

          <Button x:Name="OpenSaveFolderButton"
                  Margin="0,8,0,0"
                  Style="{StaticResource SecondaryButtonStyle}"
                  Click="OpenSaveFolderButton_OnClick" />

          <Border Margin="0,14,0,0"
                  Background="#F7F9FD"
                  BorderBrush="#E0E6F0"
                  BorderThickness="1"
                  CornerRadius="18"
                  Padding="12">
            <StackPanel>
              <TextBlock x:Name="TipsTitleTextBlock"
                         Foreground="#51627C"
                         FontSize="12"
                         FontWeight="SemiBold" />
              <TextBlock x:Name="TipsLineOneTextBlock"
                         Margin="0,8,0,0"
                         Foreground="#7B889C"
                         FontSize="12"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="TipsLineTwoTextBlock"
                         Margin="0,6,0,0"
                         Foreground="#7B889C"
                         FontSize="12"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2"
            Style="{StaticResource CardBorderStyle}"
            Padding="14,12">
      <Button x:Name="StartButton"
              Style="{StaticResource PrimaryButtonStyle}"
              Click="StartButton_OnClick" />
    </Border>
  </Grid>
</Window>
