<Window x:Class="WindosRecorder.WindowSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="430"
        Height="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#F4F6FB">
  <Grid Margin="16">
    <Border Background="White"
            BorderBrush="#E5EAF2"
            BorderThickness="1"
            CornerRadius="24"
            Padding="18">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel>
          <TextBlock x:Name="TitleTextBlock"
                     FontSize="24"
                     FontWeight="SemiBold"
                     Foreground="#1F2D3D"
                     Text="Choose Window" />
        </DockPanel>

        <TextBlock x:Name="SubtitleTextBlock"
                   Grid.Row="1"
                   Margin="0,8,0,0"
                   Foreground="#73829A"
                   FontSize="13"
                   Text="Pick the window you want to record" />

        <Border Grid.Row="2"
                Margin="0,18,0,0"
                Background="#F7F9FD"
                BorderBrush="#E3E8F2"
                BorderThickness="1"
                CornerRadius="18"
                Padding="6">
          <ListBox x:Name="WindowListBox"
                   BorderThickness="0"
                   Background="Transparent"
                   SelectionChanged="WindowListBox_OnSelectionChanged">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Margin="0,4,0,4"
                        Padding="12"
                        Background="White"
                        CornerRadius="14"
                        BorderBrush="#E7ECF4"
                        BorderThickness="1">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="○"
                               Foreground="#4C68A1"
                               FontSize="16"
                               VerticalAlignment="Top" />
                    <StackPanel Margin="12,0,0,0">
                      <TextBlock Text="{Binding Title}"
                                 Foreground="#1F2D3D"
                                 FontSize="15"
                                 FontWeight="SemiBold"
                                 TextWrapping="Wrap" />
                      <TextBlock Text="{Binding Handle}"
                                 Margin="0,4,0,0"
                                 Foreground="#8B97AA"
                                 FontSize="12" />
                    </StackPanel>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>

        <Grid Grid.Row="3"
              Margin="0,14,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="110" />
          </Grid.ColumnDefinitions>
          <Button x:Name="CancelButton"
                  Margin="0,0,8,0"
                  Click="CancelButton_OnClick"
                  Content="Cancel" />
          <Button x:Name="ConfirmButton"
                  Grid.Column="1"
                  Click="ConfirmButton_OnClick"
                  Content="OK" />
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>
