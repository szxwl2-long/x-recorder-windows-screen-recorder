<Window x:Class="WindosRecorder.SupportAuthorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="#F4F6FB">
  <Grid Margin="18">
    <Border Background="White"
            BorderBrush="#E5EAF2"
            BorderThickness="1"
            CornerRadius="22"
            Padding="18">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="TitleTextBlock"
                   Foreground="#1F2D3D"
                   FontSize="22"
                   FontWeight="SemiBold" />
        <TextBlock x:Name="MessageTextBlock"
                   Grid.Row="1"
                   Margin="0,8,0,0"
                   Foreground="#6A7890"
                   FontSize="13"
                   TextWrapping="Wrap" />

        <Grid x:Name="SupportCardsGrid"
              Grid.Row="2"
              Margin="0,18,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border x:Name="PrimarySupportCard"
                  Grid.Column="0"
                  Background="#F7F9FD"
                  BorderBrush="#DDE5F1"
                  BorderThickness="1"
                  CornerRadius="16"
                  Padding="12">
            <StackPanel>
              <TextBlock x:Name="PrimarySupportTitleTextBlock"
                         Foreground="#1F2D3D"
                         FontSize="15"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center" />
              <Border Margin="0,10,0,0"
                      Height="260"
                      Background="White"
                      BorderBrush="#D8DFEB"
                      BorderThickness="1"
                      CornerRadius="12">
                <Grid>
                  <Image x:Name="PrimarySupportImage"
                         Margin="10,2,10,12"
                         HorizontalAlignment="Center"
                         Stretch="Uniform"
                         VerticalAlignment="Top"
                         Visibility="Collapsed" />
                  <TextBlock x:Name="PrimarySupportPlaceholderTextBlock"
                             Foreground="#8A98AE"
                             FontSize="12"
                             TextWrapping="Wrap"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Grid>
              </Border>
            </StackPanel>
          </Border>

          <Border x:Name="SecondarySupportCard"
                  Grid.Column="2"
                  Background="#F7F9FD"
                  BorderBrush="#DDE5F1"
                  BorderThickness="1"
                  CornerRadius="16"
                  Padding="12">
            <StackPanel>
              <TextBlock x:Name="SecondarySupportTitleTextBlock"
                         Foreground="#1F2D3D"
                         FontSize="15"
                         FontWeight="SemiBold"
                         HorizontalAlignment="Center" />
              <Border Margin="0,10,0,0"
                      Height="260"
                      Background="White"
                      BorderBrush="#D8DFEB"
                      BorderThickness="1"
                      CornerRadius="12">
                <Grid>
                  <Image x:Name="SecondarySupportImage"
                         Margin="10,2,10,12"
                         HorizontalAlignment="Center"
                         Stretch="Uniform"
                         VerticalAlignment="Top"
                         Visibility="Collapsed" />
                  <TextBlock x:Name="SecondarySupportPlaceholderTextBlock"
                             Foreground="#8A98AE"
                             FontSize="12"
                             TextWrapping="Wrap"
                             TextAlignment="Center"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                </Grid>
              </Border>
            </StackPanel>
          </Border>
        </Grid>

        <Button x:Name="CloseButton"
                Grid.Row="3"
                Height="36"
                Margin="0,16,0,0"
                Click="CloseButton_OnClick" />
      </Grid>
    </Border>
  </Grid>
</Window>
